#!/usr/bin/env bash
set -euo pipefail

ACTIVE_FILE="$HOME/.aws/active-profile"
AWS_CONFIG="$HOME/.aws/config"
VERSION="1.4.0"
SCRIPT_URL="https://raw.githubusercontent.com/funactuator/tools/main/iaws/iaws"
SETUP_DOC="https://github.com/funactuator/tools/blob/main/iaws/AWS-SETUP.md"

# --- Colors (disabled if not a terminal) ---
if [[ -t 2 ]]; then
  GREEN='\033[0;32m' YELLOW='\033[1;33m' RED='\033[0;31m'
  CYAN='\033[0;36m' BOLD='\033[1m' DIM='\033[2m' RESET='\033[0m'
else
  GREEN='' YELLOW='' RED='' CYAN='' BOLD='' DIM='' RESET=''
fi

info()  { printf "${GREEN}%s${RESET}\n" "$*" >&2; }
warn()  { printf "${YELLOW}%s${RESET}\n" "$*" >&2; }
err()   { printf "${RED}%s${RESET}\n" "$*" >&2; }

# --- Prereq checks ---
check_prereqs() {
  local ok=1

  if ! command -v aws &>/dev/null; then
    err "AWS CLI not found. Please install AWS CLI v2."
    ok=0
  elif ! aws --version 2>&1 | grep -q 'aws-cli/2'; then
    err "AWS CLI v1 detected. iaws requires AWS CLI v2."
    ok=0
  fi

  if [[ ! -f "$AWS_CONFIG" ]]; then
    err "~/.aws/config not found. You need at least one SSO profile configured."
    ok=0
  elif ! grep -q '^\[profile ' "$AWS_CONFIG" 2>/dev/null; then
    err "No profiles found in ~/.aws/config. Add at least one [profile ...] block."
    ok=0
  fi

  if [[ "$ok" -eq 0 ]]; then
    printf "${YELLOW}  Setup guide: %s${RESET}\n" "$SETUP_DOC" >&2
    exit 1
  fi
}

# --- Helpers ---
get_profiles() {
  if [[ -r "$AWS_CONFIG" ]]; then
    awk '/^\[profile / { print substr($0, 10, length($0)-10) }' "$AWS_CONFIG"
  else
    aws configure list-profiles 2>/dev/null
  fi
}

parse_profile_field() {
  local profile="$1" field="$2"
  awk -v prof="$profile" -v key="$field" '
    /^\[profile / { cur = substr($0, 10, length($0)-10) }
    cur == prof && $0 ~ "^"key" *= *" {
      sub(/^[^=]+=[ \t]*/, ""); print; exit
    }
  ' "$AWS_CONFIG"
}

get_active() {
  if [[ -f "$ACTIVE_FILE" ]]; then
    cat "$ACTIVE_FILE"
  else
    echo ""
  fi
}

set_active() { echo "$1" > "$ACTIVE_FILE"; }

profile_exists() { get_profiles | grep -qx "$1"; }

is_logged_in() {
  local p="${1:-$(get_active)}"
  aws configure export-credentials --profile "$p" --format env &>/dev/null
}

require_active() {
  local p
  p="$(get_active)"
  if [[ -z "$p" ]]; then
    err "No active profile. Run: iaws use"
    exit 1
  fi
  echo "$p"
}

# --- Commands ---

cmd_list() {
  check_prereqs
  local active profiles
  active="$(get_active)"
  profiles="$(get_profiles)"

  if [[ -z "$profiles" ]]; then
    warn "No profiles found in ~/.aws/config"
    return 1
  fi

  printf "\n${BOLD}  %-30s %-16s %s${RESET}\n" "PROFILE" "ACCOUNT" "ROLE"
  printf "  %-30s %-16s %s\n" "-------" "-------" "----"

  while IFS= read -r p; do
    local acct role marker color
    acct=$(parse_profile_field "$p" "sso_account_id")
    role=$(parse_profile_field "$p" "sso_role_name")
    [[ -z "$acct" ]] && acct="-"
    [[ -z "$role" ]] && role="-"

    if [[ "$p" == "$active" ]]; then
      marker=">"
      color="$GREEN"
    else
      marker=" "
      color=""
    fi

    printf "${color}%s %-30s %-16s %s${RESET}\n" "$marker" "$p" "$acct" "$role"
  done <<< "$profiles"
  echo
}

cmd_use() {
  check_prereqs
  local choice

  if [[ $# -ge 1 ]]; then
    choice="$1"
    if ! profile_exists "$choice"; then
      err "Profile '$choice' not found."
      warn "Available profiles:"
      get_profiles | sed 's/^/  /' >&2
      exit 1
    fi
  elif command -v fzf &>/dev/null; then
    choice=$(get_profiles | fzf --height=10 --prompt="Select AWS profile: " --border --reverse) || true
    if [[ -z "$choice" ]]; then
      warn "No profile selected."
      return 1
    fi
  else
    # Numbered menu fallback
    local profiles_arr=()
    while IFS= read -r p; do
      profiles_arr+=("$p")
    done < <(get_profiles)

    if [[ ${#profiles_arr[@]} -eq 0 ]]; then
      err "No profiles found."
      return 1
    fi

    echo "Available profiles:" >&2
    local i
    for i in "${!profiles_arr[@]}"; do
      printf "  ${CYAN}%d)${RESET} %s\n" "$((i + 1))" "${profiles_arr[$i]}" >&2
    done
    echo >&2

    local num
    read -r -p "Select profile [1-${#profiles_arr[@]}]: " num
    if [[ "$num" =~ ^[0-9]+$ ]] && (( num >= 1 && num <= ${#profiles_arr[@]} )); then
      choice="${profiles_arr[$((num - 1))]}"
    else
      err "Invalid selection."
      return 1
    fi
  fi

  set_active "$choice"
  info "Active profile set to: $choice"
}

cmd_status() {
  check_prereqs
  local p
  p="$(require_active)"

  local region acct role sso_state sso_color
  region=$(parse_profile_field "$p" "region")
  acct=$(parse_profile_field "$p" "sso_account_id")
  role=$(parse_profile_field "$p" "sso_role_name")
  [[ -z "$region" ]] && region="not set"
  [[ -z "$acct" ]] && acct="-"
  [[ -z "$role" ]] && role="-"

  if is_logged_in "$p"; then
    sso_state="valid"
    sso_color="$GREEN"
  else
    sso_state="expired"
    sso_color="$RED"
  fi

  echo
  printf "  ${BOLD}Profile:${RESET}  %s\n" "$p"
  printf "  ${BOLD}Account:${RESET}  %s\n" "$acct"
  printf "  ${BOLD}Role:${RESET}     %s\n" "$role"
  printf "  ${BOLD}Region:${RESET}   %s\n" "$region"
  printf "  ${BOLD}SSO:${RESET}      ${sso_color}%s${RESET}\n" "$sso_state"
  echo
}

cmd_login() {
  check_prereqs
  local p
  p="$(require_active)"
  info "Logging in to SSO for profile: $p"
  aws sso login --profile "$p"
  info "SSO login successful."
}

cmd_load() {
  # This command only works when iaws is a shell function (installed via iaws install)
  # If called directly as a script, it cannot export to the parent shell
  err "'iaws load' only works after running: iaws install"
  err "Then restart your terminal and run: iaws load"
  exit 1
}

cmd_env() {
  check_prereqs
  local p
  p="$(require_active)"

  local creds
  if ! creds="$(aws configure export-credentials --profile "$p" --format env 2>/dev/null)"; then
    warn "SSO session expired. Logging in..." >&2
    aws sso login --profile "$p" >&2
    creds="$(aws configure export-credentials --profile "$p" --format env)"
  fi

  echo "$creds"
  local region
  region="$(parse_profile_field "$p" "region")"
  [[ -z "$region" ]] && region="ap-south-1"
  echo "export AWS_REGION=\"$region\""
  echo "export AWS_DEFAULT_REGION=\"$region\""
  echo "export AWS_PROFILE=\"$p\""
}

cmd_upgrade() {
  local script_path="$HOME/.aws/iaws"

  info "Checking for updates..."

  local tmp
  tmp="$(mktemp)"

  if ! curl -sL "$SCRIPT_URL" -o "$tmp" 2>/dev/null; then
    err "Failed to download latest version. Check your internet connection."
    rm -f "$tmp"
    exit 1
  fi

  # Check if downloaded file looks valid
  if ! grep -q "iaws - AWS Profile Manager" "$tmp" 2>/dev/null; then
    err "Downloaded file looks invalid. Aborting upgrade."
    rm -f "$tmp"
    exit 1
  fi

  local latest_version
  latest_version=$(grep '^VERSION=' "$tmp" | cut -d'"' -f2)

  if [[ "$latest_version" == "$VERSION" ]]; then
    info "Already on latest version (v$VERSION). Nothing to do."
    rm -f "$tmp"
    return 0
  fi

  cp "$tmp" "$script_path"
  chmod +x "$script_path"
  rm -f "$tmp"

  info "Upgraded: v$VERSION → v$latest_version"
  warn "Restart your terminal or run: source ~/.zshrc"
}

cmd_uninstall() {
  local script_path="$HOME/.aws/iaws"
  local shell_rc

  if [[ -n "${ZSH_VERSION:-}" ]] || [[ "$SHELL" == */zsh ]]; then
    shell_rc="$HOME/.zshrc"
  else
    shell_rc="$HOME/.bashrc"
  fi

  # Confirm
  printf "${YELLOW}This will remove iaws from %s and clean up %s${RESET}\n" "$script_path" "$shell_rc" >&2
  read -r -p "Are you sure? [y/N] " confirm
  if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
    warn "Aborted."
    return 0
  fi

  # Remove shell config block
  local marker="# iaws - AWS Profile Manager"
  if grep -qF "$marker" "$shell_rc" 2>/dev/null; then
    perl -i -0pe "s/\n${marker}\nexport PATH=.*?\n.*?iaws\(\).*?\{.*?\}\n//s" "$shell_rc" 2>/dev/null \
      || sed -i '' "/# iaws - AWS Profile Manager/,/^}/d" "$shell_rc"
    info "Removed iaws config from $shell_rc"
  fi

  # Remove active-profile state file
  rm -f "$HOME/.aws/active-profile"

  # Remove script itself (last step)
  rm -f "$script_path"
  info "Removed $script_path"

  echo
  warn "iaws uninstalled. Restart your terminal or run: source $shell_rc"
}

cmd_install() {
  local script_path="$HOME/.aws/iaws"
  local shell_rc

  # Detect shell config file
  if [[ -n "${ZSH_VERSION:-}" ]] || [[ "$SHELL" == */zsh ]]; then
    shell_rc="$HOME/.zshrc"
  else
    shell_rc="$HOME/.bashrc"
  fi

  # Ensure script is in the right place
  local self
  self="$(realpath "${BASH_SOURCE[0]}" 2>/dev/null || readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
  if [[ "$self" != "$script_path" ]]; then
    cp "$self" "$script_path"
    info "Copied iaws to $script_path"
  fi
  chmod +x "$script_path"

  # Shell config block to inject
  local marker="# iaws - AWS Profile Manager"
  local new_block
  new_block="$(cat <<'SHELLCONFIG'

# iaws - AWS Profile Manager
export PATH="$HOME/.aws:$PATH"
iaws() {
  if [[ "${1:-}" == "load" ]]; then
    eval "$(~/.aws/iaws env)"
  else
    ~/.aws/iaws "$@"
  fi
}
SHELLCONFIG
)"

  if ! grep -qF "$marker" "$shell_rc" 2>/dev/null; then
    # Fresh install — also remove any old awsp block if present
    local old_marker="# awsp - AWS Profile Manager"
    if grep -qF "$old_marker" "$shell_rc" 2>/dev/null; then
      perl -i -0pe "s/\n# awsp - AWS Profile Manager\nexport PATH=.*?\n.*?awsp\(\).*?\{.*?\}\n//s" "$shell_rc" 2>/dev/null \
        || sed -i '' "/# awsp - AWS Profile Manager/,/^}/d" "$shell_rc"
      info "Removed old awsp config from $shell_rc"
    fi
    echo "$new_block" >> "$shell_rc"
    info "Added iaws to $shell_rc"
  else
    # Already installed - replace existing block with latest
    perl -i -0pe "s|\n# iaws - AWS Profile Manager\n.*?(?=\n\n|\n#|\z)|${new_block}|s" "$shell_rc" 2>/dev/null \
      || { warn "Could not auto-update $shell_rc block. Please re-run: iaws uninstall && iaws install"; }
    info "Updated iaws config in $shell_rc"
  fi

  echo
  info "Installation complete!"
  echo
  echo "  Restart your terminal or run:"
  printf "    ${CYAN}source %s${RESET}\n" "$shell_rc"
  echo
  echo "  Then use:"
  printf "    ${CYAN}iaws use${RESET}       Select a profile\n"
  printf "    ${CYAN}iaws status${RESET}    Check current profile & SSO state\n"
  printf "    ${CYAN}iaws list${RESET}      List all profiles\n"
  printf "    ${CYAN}iaws load${RESET}      Load credentials into current shell\n"
  echo
}

cmd_help() {
  printf "\n" >&2
  printf "  ${BOLD}iaws${RESET} - AWS Profile Manager v%s\n\n" "$VERSION" >&2
  printf "  ${BOLD}USAGE${RESET}\n" >&2
  printf "    iaws <command> [args]\n\n" >&2
  printf "  ${BOLD}COMMANDS${RESET}\n" >&2
  printf "    list,   ls      List all available profiles\n" >&2
  printf "    use,    set     Switch active profile (interactive if no arg)\n" >&2
  printf "    status, st      Show current profile & SSO state ${DIM}(default)${RESET}\n" >&2
  printf "    login           Force SSO login for active profile\n" >&2
  printf "    load            Load credentials into current shell ${DIM}(requires install)${RESET}\n" >&2
  printf "    env             Print credential export statements\n" >&2
  printf "    upgrade         Upgrade iaws to latest version from GitHub\n" >&2
  printf "    uninstall       Remove iaws and clean up shell config\n" >&2
  printf "    install         Set up shell config (PATH + shell function)\n" >&2
  printf "    help            Show this help\n\n" >&2
  printf "  ${BOLD}EXAMPLES${RESET}\n" >&2
  printf "    ${CYAN}iaws use${RESET}                  # Interactive profile picker\n" >&2
  printf "    ${CYAN}iaws use my-profile${RESET}       # Set profile directly\n" >&2
  printf "    ${CYAN}iaws status${RESET}               # Check what's active\n" >&2
  printf "    ${CYAN}iaws load${RESET}                 # Load credentials into current shell\n\n" >&2
  printf "  ${BOLD}INSTALL${RESET}\n" >&2
  printf "    curl -sL <url> -o ~/.aws/iaws && chmod +x ~/.aws/iaws && ~/.aws/iaws install\n\n" >&2
}

# --- Main dispatch ---
case "${1:-status}" in
  list|ls)          cmd_list ;;
  use|set)          shift; cmd_use "$@" ;;
  status|st)        cmd_status ;;
  login)            cmd_login ;;
  env)              cmd_env ;;
  load)             cmd_load ;;
  upgrade|update)   cmd_upgrade ;;
  uninstall|remove) cmd_uninstall ;;
  install)          cmd_install ;;
  help|-h|--help)   cmd_help ;;
  version|--version|-v) echo "iaws v${VERSION}" ;;
  *)                err "Unknown command: $1"; cmd_help; exit 1 ;;
esac
