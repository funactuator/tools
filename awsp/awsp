#!/usr/bin/env bash
set -euo pipefail

ACTIVE_FILE="$HOME/.aws/active-profile"
AWS_CONFIG="$HOME/.aws/config"
VERSION="1.0.0"

# --- Colors (disabled if not a terminal) ---
if [[ -t 2 ]]; then
  GREEN='\033[0;32m' YELLOW='\033[1;33m' RED='\033[0;31m'
  CYAN='\033[0;36m' BOLD='\033[1m' DIM='\033[2m' RESET='\033[0m'
else
  GREEN='' YELLOW='' RED='' CYAN='' BOLD='' DIM='' RESET=''
fi

info()  { printf "${GREEN}%s${RESET}\n" "$*" >&2; }
warn()  { printf "${YELLOW}%s${RESET}\n" "$*" >&2; }
err()   { printf "${RED}%s${RESET}\n" "$*" >&2; }

# --- Helpers ---
get_profiles() { aws configure list-profiles 2>/dev/null; }

get_active() {
  if [[ -f "$ACTIVE_FILE" ]]; then
    cat "$ACTIVE_FILE"
  else
    echo ""
  fi
}

set_active() { echo "$1" > "$ACTIVE_FILE"; }

profile_exists() { get_profiles | grep -qx "$1"; }

is_logged_in() {
  local p="${1:-$(get_active)}"
  aws configure export-credentials --profile "$p" --format env &>/dev/null
}

require_active() {
  local p
  p="$(get_active)"
  if [[ -z "$p" ]]; then
    err "No active profile. Run: awsp use"
    exit 1
  fi
  echo "$p"
}

# --- Commands ---

cmd_list() {
  local active profiles
  active="$(get_active)"
  profiles="$(get_profiles)"

  if [[ -z "$profiles" ]]; then
    warn "No profiles found in ~/.aws/config"
    return 1
  fi

  printf "\n${BOLD}  %-30s %-16s %s${RESET}\n" "PROFILE" "ACCOUNT" "ROLE"
  printf "  %-30s %-16s %s\n" "-------" "-------" "----"

  while IFS= read -r p; do
    local acct role marker color
    acct=$(aws configure get sso_account_id --profile "$p" 2>/dev/null || echo "-")
    role=$(aws configure get sso_role_name --profile "$p" 2>/dev/null || echo "-")

    if [[ "$p" == "$active" ]]; then
      marker=">"
      color="$GREEN"
    else
      marker=" "
      color=""
    fi

    printf "${color}%s %-30s %-16s %s${RESET}\n" "$marker" "$p" "$acct" "$role"
  done <<< "$profiles"
  echo
}

cmd_use() {
  local choice

  if [[ $# -ge 1 ]]; then
    choice="$1"
    if ! profile_exists "$choice"; then
      err "Profile '$choice' not found."
      warn "Available profiles:"
      get_profiles | sed 's/^/  /' >&2
      exit 1
    fi
  elif command -v fzf &>/dev/null; then
    choice=$(get_profiles | fzf --height=10 --prompt="Select AWS profile: " --border --reverse) || true
    if [[ -z "$choice" ]]; then
      warn "No profile selected."
      return 1
    fi
  else
    # Numbered menu fallback
    local profiles_arr=()
    while IFS= read -r p; do
      profiles_arr+=("$p")
    done < <(get_profiles)

    if [[ ${#profiles_arr[@]} -eq 0 ]]; then
      err "No profiles found."
      return 1
    fi

    echo "Available profiles:" >&2
    local i
    for i in "${!profiles_arr[@]}"; do
      printf "  ${CYAN}%d)${RESET} %s\n" "$((i + 1))" "${profiles_arr[$i]}" >&2
    done
    echo >&2

    local num
    read -r -p "Select profile [1-${#profiles_arr[@]}]: " num
    if [[ "$num" =~ ^[0-9]+$ ]] && (( num >= 1 && num <= ${#profiles_arr[@]} )); then
      choice="${profiles_arr[$((num - 1))]}"
    else
      err "Invalid selection."
      return 1
    fi
  fi

  set_active "$choice"
  info "Active profile set to: $choice"
}

cmd_status() {
  local p
  p="$(require_active)"

  local region acct role sso_state sso_color
  region=$(aws configure get region --profile "$p" 2>/dev/null || echo "not set")
  acct=$(aws configure get sso_account_id --profile "$p" 2>/dev/null || echo "-")
  role=$(aws configure get sso_role_name --profile "$p" 2>/dev/null || echo "-")

  if is_logged_in "$p"; then
    sso_state="valid"
    sso_color="$GREEN"
  else
    sso_state="expired"
    sso_color="$RED"
  fi

  echo
  printf "  ${BOLD}Profile:${RESET}  %s\n" "$p"
  printf "  ${BOLD}Account:${RESET}  %s\n" "$acct"
  printf "  ${BOLD}Role:${RESET}     %s\n" "$role"
  printf "  ${BOLD}Region:${RESET}   %s\n" "$region"
  printf "  ${BOLD}SSO:${RESET}      ${sso_color}%s${RESET}\n" "$sso_state"
  echo
}

cmd_login() {
  local p
  p="$(require_active)"
  info "Logging in to SSO for profile: $p"
  aws sso login --profile "$p"
  info "SSO login successful."
}

cmd_env() {
  local p
  p="$(require_active)"

  local creds
  if ! creds="$(aws configure export-credentials --profile "$p" --format env 2>/dev/null)"; then
    warn "SSO session expired. Logging in..." >&2
    aws sso login --profile "$p" >&2
    creds="$(aws configure export-credentials --profile "$p" --format env)"
  fi

  echo "$creds"
  local region
  region="$(aws configure get region --profile "$p" 2>/dev/null || echo "ap-south-1")"
  echo "export AWS_REGION=\"$region\""
  echo "export AWS_DEFAULT_REGION=\"$region\""
  echo "export AWS_PROFILE=\"$p\""
}

cmd_install() {
  local script_path="$HOME/.aws/awsp"
  local shell_rc

  # Detect shell config file
  if [[ -n "${ZSH_VERSION:-}" ]] || [[ "$SHELL" == */zsh ]]; then
    shell_rc="$HOME/.zshrc"
  else
    shell_rc="$HOME/.bashrc"
  fi

  # Ensure script is in the right place
  local self
  self="$(realpath "${BASH_SOURCE[0]}" 2>/dev/null || readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
  if [[ "$self" != "$script_path" ]]; then
    cp "$self" "$script_path"
    info "Copied awsp to $script_path"
  fi
  chmod +x "$script_path"

  # Add shell config (idempotent)
  local marker="# awsp - AWS Profile Manager"
  if ! grep -qF "$marker" "$shell_rc" 2>/dev/null; then
    {
      echo ""
      echo "$marker"
      echo 'export PATH="$HOME/.aws:$PATH"'
      echo 'alias awsenv='"'"'eval "$(awsp env)"'"'"
    } >> "$shell_rc"
    info "Added awsp to $shell_rc"
  else
    info "Shell config already set up in $shell_rc"
  fi

  echo
  info "Installation complete!"
  echo
  echo "  Restart your terminal or run:"
  printf "    ${CYAN}source %s${RESET}\n" "$shell_rc"
  echo
  echo "  Then use:"
  printf "    ${CYAN}awsp use${RESET}       Select a profile\n"
  printf "    ${CYAN}awsp status${RESET}    Check current profile & SSO state\n"
  printf "    ${CYAN}awsp list${RESET}      List all profiles\n"
  printf "    ${CYAN}awsenv${RESET}         Load credentials into shell\n"
  echo
}

cmd_help() {
  cat >&2 <<EOF

  ${BOLD}awsp${RESET} - AWS Profile Manager v${VERSION}

  ${BOLD}USAGE${RESET}
    awsp <command> [args]

  ${BOLD}COMMANDS${RESET}
    list,   ls      List all available profiles
    use,    set     Switch active profile (interactive if no arg)
    status, st      Show current profile & SSO state ${DIM}(default)${RESET}
    login           Force SSO login for active profile
    env             Export credentials ${DIM}(use: eval "\$(awsp env)" or alias: awsenv)${RESET}
    install         Set up shell config (PATH + alias)
    help            Show this help

  ${BOLD}EXAMPLES${RESET}
    awsp use                  # Interactive profile picker
    awsp use my-profile       # Set profile directly
    awsp status               # Check what's active
    awsenv                    # Load credentials into shell

  ${BOLD}INSTALL${RESET}
    curl -sL <url> -o ~/.aws/awsp && chmod +x ~/.aws/awsp && ~/.aws/awsp install

EOF
}

# --- Main dispatch ---
case "${1:-status}" in
  list|ls)          cmd_list ;;
  use|set)          shift; cmd_use "$@" ;;
  status|st)        cmd_status ;;
  login)            cmd_login ;;
  env)              cmd_env ;;
  install)          cmd_install ;;
  help|-h|--help)   cmd_help ;;
  version|--version|-v) echo "awsp v${VERSION}" ;;
  *)                err "Unknown command: $1"; cmd_help; exit 1 ;;
esac
